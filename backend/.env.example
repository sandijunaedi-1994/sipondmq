# Salin file ini menjadi .env lalu isi nilainya

# ---- DATABASE ----
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/NAMA_DATABASE"

# ---- SERVER ----
PORT=3000

# ---- AUTH ----
JWT_SECRET="isi_dengan_secret_yang_panjang_dan_random"

# ---- MIDTRANS ----
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY="Mid-server-xxxx"
MIDTRANS_CLIENT_KEY="Mid-client-xxxx"
