model RegistrationData {
  id               String                         @id
  registrationId   String                         @unique
  nickname         String?
  birthPlace       String?
  birthDate        DateTime?
  nik              String?
  nisn             String?
  childNumber      Int?
  siblingCount     Int?
  achievements     String?                        @db.Text
  medicalHistory   String?                        @db.Text
  talents          String?                        @db.Text
  fatherName       String?
  fatherAge        Int?
  fatherEducation  String?
  fatherOccupation String?
  fatherIncome     String?
  fatherAddress    String?                        @db.Text
  motherName       String?
  motherAge        Int?
  motherEducation  String?
  motherOccupation String?
  motherIncome     String?
  motherAddress    String?                        @db.Text
  parentStatus     RegistrationData_parentStatus?
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime
  noKk             String?
  MqSibling        MqSibling[]
  Registration     Registration                   @relation(fields: [registrationId], references: [id])
  Sibling          Sibling[]
}

model Santri {
  id                     String                   @id
  nis                    String?                  @unique @db.VarChar(30)
  markazId               Int?
  kelas                  String?                  @db.VarChar(50)
  asrama                 String?                  @db.VarChar(100)
  tahunMasuk             Int?
  status                 Santri_status            @default(AKTIF)
  fotoUrl                String?                  @db.VarChar(500)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  sppNominal             Decimal?                 @db.Decimal(12, 0)
  Donasi                 Donasi[]
  HealthRecord           HealthRecord[]
  Kehadiran              Kehadiran[]
  Kepengurusan           Kepengurusan[]
  MatanCapaian           MatanCapaian[]
  Pelanggaran            Pelanggaran[]
  Pembayaran             Pembayaran[]
  Perizinan              Perizinan[]
  Prestasi               Prestasi[]
  Registration           Registration             @relation(fields: [id], references: [id])
  Markaz                 Markaz?                  @relation(fields: [markazId], references: [id])
  Sertifikat             Sertifikat[]
  SuratPeringatan        SuratPeringatan[]
  Tagihan                Tagihan[]
  TahfidzCapaianTahapan  TahfidzCapaianTahapan[]
  TahfidzCatatanPengampu TahfidzCatatanPengampu[]
  TahfidzHafalanHarian   TahfidzHafalanHarian[]
  UangSaku               UangSaku?
  UangSakuMutasi         UangSakuMutasi[]
  WaliSantri             WaliSantri[]

  @@index([markazId], map: "Santri_markazId_fkey")
}

model Sertifikat {
  id         String    @id
  santriId   String
  prestasiId String?
  judul      String    @db.VarChar(300)
  penerbit   String    @db.VarChar(200)
  tanggal    DateTime  @db.Date
  fileUrl    String?   @db.VarChar(500)
  createdAt  DateTime  @default(now())
  Prestasi   Prestasi? @relation(fields: [prestasiId], references: [id])
  Santri     Santri    @relation(fields: [santriId], references: [id], onDelete: Cascade)

  @@index([prestasiId], map: "Sertifikat_prestasiId_fkey")
  @@index([santriId], map: "Sertifikat_santriId_fkey")
}

model Sibling {
  id                 String           @id
  registrationDataId String
  name               String
  age                Int?
  education          String?
  occupation         String?
  RegistrationData   RegistrationData @relation(fields: [registrationDataId], references: [id])

  @@index([registrationDataId], map: "Sibling_registrationDataId_fkey")
}

model SuratPeringatan {
  id            String                  @id
  santriId      String
  nomorSurat    String                  @unique @db.VarChar(100)
  tanggal       DateTime                @db.Date
  tingkat       SuratPeringatan_tingkat
  perihal       String                  @db.VarChar(300)
  fileUrl       String?                 @db.VarChar(500)
  pelanggaranId String?
  createdAt     DateTime                @default(now())
  Pelanggaran   Pelanggaran?            @relation(fields: [pelanggaranId], references: [id])
  Santri        Santri                  @relation(fields: [santriId], references: [id], onDelete: Cascade)

  @@index([pelanggaranId], map: "SuratPeringatan_pelanggaranId_fkey")
  @@index([santriId], map: "SuratPeringatan_santriId_fkey")
}

model SurveyKunjungan {
  id             String                 @id
  namaSantri     String                 @db.VarChar(150)
  tanggal        DateTime               @db.Date
  jam            String                 @db.VarChar(10)
  program        String                 @db.VarChar(10)
  gender         SurveyKunjungan_gender
  harapan        String                 @db.Text
  isHandled      Boolean                @default(false)
  createdAt      DateTime               @default(now())
  catatan        String?                @db.Text
  noHp           String                 @default("") @db.VarChar(20)
  registrationId String?
  status         SurveyKunjungan_status @default(MENUNGGU)
  Registration   Registration?          @relation(fields: [registrationId], references: [id])

  @@index([registrationId], map: "SurveyKunjungan_registrationId_fkey")
}

model Tagihan {
  id             String           @id
  santriId       String
  jenisId        Int
  label          String           @db.VarChar(200)
  tahunAjaran    String?          @db.VarChar(10)
  bulan          Int?             @db.TinyInt
  nominal        Decimal          @db.Decimal(12, 0)
  jatuhTempo     DateTime         @db.Date
  status         Tagihan_status   @default(BELUM)
  keterangan     String?          @db.Text
  isTentative    Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  PembayaranItem PembayaranItem[]
  TagihanJenis   TagihanJenis     @relation(fields: [jenisId], references: [id])
  Santri         Santri           @relation(fields: [santriId], references: [id], onDelete: Cascade)

  @@index([jenisId], map: "Tagihan_jenisId_fkey")
  @@index([santriId], map: "Tagihan_santriId_fkey")
}

model TagihanJenis {
  id        Int               @id @default(autoincrement())
  kode      TagihanJenis_kode
  label     String            @db.VarChar(100)
  deskripsi String?           @db.Text
  aktif     Boolean           @default(true)
  Tagihan   Tagihan[]
}

model TahfidzCapaianTahapan {
  id             String                       @id
  santriId       String
  tahapanId      Int                          @db.UnsignedTinyInt
  targetTanggal  DateTime?                    @db.Date
  selesaiTanggal DateTime?                    @db.Date
  status         TahfidzCapaianTahapan_status @default(BELUM)
  catatan        String?                      @db.Text
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime
  Santri         Santri                       @relation(fields: [santriId], references: [id], onDelete: Cascade)
  TahfidzTahapan TahfidzTahapan               @relation(fields: [tahapanId], references: [id])

  @@unique([santriId, tahapanId])
  @@index([tahapanId], map: "TahfidzCapaianTahapan_tahapanId_fkey")
}

model TahfidzCatatanPengampu {
  id           String                       @id
  santriId     String
  pengampuId   String?
  namaPengampu String?                      @db.VarChar(150)
  jenis        TahfidzCatatanPengampu_jenis @default(UMUM)
  catatan      String                       @db.Text
  createdAt    DateTime                     @default(now())
  Santri       Santri                       @relation(fields: [santriId], references: [id], onDelete: Cascade)

  @@index([santriId], map: "TahfidzCatatanPengampu_santriId_fkey")
}

model TahfidzHafalanHarian {
  id         String   @id
  santriId   String
  tanggal    DateTime @db.Date
  targetHal  Int      @default(5) @db.UnsignedTinyInt
  capaianHal Int      @default(0) @db.UnsignedTinyInt
  totalJuz   Decimal? @db.Decimal(4, 1)
  keterangan String?  @db.VarChar(300)
  createdAt  DateTime @default(now())
  Santri     Santri   @relation(fields: [santriId], references: [id], onDelete: Cascade)

  @@unique([santriId, tanggal])
}

model TahfidzTahapan {
  id                    Int                     @id @default(autoincrement()) @db.UnsignedTinyInt
  urutan                Int                     @db.UnsignedTinyInt
  nama                  String                  @db.VarChar(100)
  deskripsi             String?                 @db.Text
  TahfidzCapaianTahapan TahfidzCapaianTahapan[]
}

model UangSaku {
  id          String   @id
  santriId    String   @unique
  saldo       Decimal  @default(0) @db.Decimal(12, 0)
  updatedAt   DateTime
  limitHarian Decimal? @db.Decimal(12, 0)
  Santri      Santri   @relation(fields: [santriId], references: [id], onDelete: Cascade)
}

model UangSakuMutasi {
  id           String              @id
  santriId     String
  pembayaranId String?
  tipe         UangSakuMutasi_tipe
  nominal      Decimal             @db.Decimal(12, 0)
  saldoSebelum Decimal             @db.Decimal(12, 0)
  saldoSesudah Decimal             @db.Decimal(12, 0)
  keterangan   String?             @db.VarChar(200)
  createdAt    DateTime            @default(now())
  Pembayaran   Pembayaran?         @relation(fields: [pembayaranId], references: [id])
  Santri       Santri              @relation(fields: [santriId], references: [id], onDelete: Cascade)

  @@index([pembayaranId], map: "UangSakuMutasi_pembayaranId_fkey")
  @@index([santriId], map: "UangSakuMutasi_santriId_fkey")
}

model User {
  id                                            String         @id
  phone                                         String?        @unique
  email                                         String?        @unique
  password                                      String
  role                                          User_role      @default(CALON_WALI)
  createdAt                                     DateTime       @default(now())
  updatedAt                                     DateTime
  namaLengkap                                   String?        @db.VarChar(150)
  verifiedAt                                    DateTime?
  permissions                                   String?        @db.LongText
  ChatPesan                                     ChatPesan[]
  Donasi                                        Donasi[]
  ExamAttempt                                   ExamAttempt[]
  Notifikasi                                    Notifikasi[]
  Pembayaran                                    Pembayaran[]
  Perizinan                                     Perizinan[]
  Registration_Registration_interviewerIdToUser Registration[] @relation("Registration_interviewerIdToUser")
  Registration_Registration_userIdToUser        Registration[] @relation("Registration_userIdToUser")
  WaliSantri                                    WaliSantri[]

  @@index([role])
}

model WaliSantri {
  id        Int                 @id @default(autoincrement())
  userId    String
  santriId  String
  hubungan  WaliSantri_hubungan @default(WALI)
  isPrimary Boolean             @default(false)
  createdAt DateTime            @default(now())
  Santri    Santri              @relation(fields: [santriId], references: [id], onDelete: Cascade)
  User      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, santriId])
  @@index([santriId], map: "WaliSantri_santriId_fkey")
}

