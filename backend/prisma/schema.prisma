enum StatusCatatan {
  PENDING
  SELESAI
}

model CatatanAdmin {
  id        String        @id @default(uuid())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  tanggal   DateTime      @db.Date
  judul     String?       @db.VarChar(200)
  tugas     String        @db.Text
  warna     String?       @db.VarChar(50)
  labels    Json?
  status    StatusCatatan @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// ==========================================
// 19. BROADCAST & INFORMASI
// ==========================================

enum TipeBroadcast {
  UMUM
  PENTING
}

enum TargetBroadcast {
  SEMUA
  PPDB
  SANTRI_AKTIF
}

model Broadcast {
  id        String          @id @default(uuid())
  judul     String          @db.VarChar(200)
  pesan     String          @db.Text
  tipe      TipeBroadcast   @default(UMUM)
  target    TargetBroadcast @default(SEMUA)
  markazId  Int?
  markaz    Markaz?         @relation(fields: [markazId], references: [id])
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

// ==========================================
// PENGATURAN KEUANGAN
// ==========================================

model FinanceTahunAjaran {
  id             String    @id @default(uuid())
  nama           String    @unique @db.VarChar(50) // e.g. "2027/2028"
  tanggalMulai   DateTime? @db.Date
  tanggalSelesai DateTime? @db.Date
  aktif          Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  periodes FinancePeriodePendaftaran[]
}

model FinancePeriodePendaftaran {
  id             String             @id @default(uuid())
  tahunAjaranId  String
  tahunAjaran    FinanceTahunAjaran @relation(fields: [tahunAjaranId], references: [id], onDelete: Cascade)
  nama           String             @db.VarChar(100) // e.g. "Gelombang 1"
  tanggalMulai   DateTime           @db.Date
  tanggalSelesai DateTime           @db.Date
  program        MqProgram // SD, SMP, SMA, MAHAD_ALY
  uangPangkal    Decimal            @db.Decimal(12, 0)
  spp            Decimal            @db.Decimal(12, 0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([tahunAjaranId, nama, program])
}

// ==========================================
// PORTAL APP LAUNCHER
// ==========================================

model PortalApp {
  id        String   @id @default(uuid())
  nama      String   @db.VarChar(150)
  deskripsi String?  @db.Text
  url       String   @db.VarChar(255)
  ikon      String?  @db.VarChar(100)
  isAktif   Boolean  @default(true)
  urutan    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum McDaftarTugas_kategori {
  JANGKA_PENDEK
  JANGKA_PANJANG
  REQUEST_UNIT
}

enum McPlan_type {
  YEARLY
  SEMIANNUAL
  MONTHLY
  WEEKLY
}

enum McUnitRequest_urgency {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum McRoutineSchedule_status {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum McDailyTask_status {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum McUnitRequest_status {
  PENDING
  APPROVED
  INTEGRATED
  REJECTED
}

enum McPlan_status {
  DRAFT
  PENDING
  ON_PROGRESS
  COMPLETED
  DELAYED
  CANCELLED
}

model McBudget {
  id            String   @id
  planId        String
  category      String
  estimatedCost Decimal  @db.Decimal(12, 0)
  description   String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  McPlan        McPlan   @relation(fields: [planId], references: [id])

  @@index([planId], map: "McBudget_planId_fkey")
}

model McDaftarTugas {
  id                String                  @id
  rencanaPekerjaan  String
  kategori          McDaftarTugas_kategori?
  status            String                  @default("REGISTER")
  sumberTugas       String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime
  kategoriPekerjaan String?
  markaz            String?
  namaRequestor     String?
  keterangan        String?                 @db.Text
  McPlan            McPlan[]
}

model McDailyTask {
  id         String             @id
  planId     String
  workerName String
  taskDetail String             @db.Text
  taskDate   DateTime           @db.Date
  status     McDailyTask_status @default(PENDING)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime
  McPlan     McPlan             @relation(fields: [planId], references: [id])

  @@index([planId], map: "McDailyTask_planId_fkey")
}

model McMaterial {
  id        String   @id
  kode      String   @unique
  nama      String
  kategori  String
  satuan    String
  harga     Decimal  @db.Decimal(12, 0)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model McPlan {
  id              String          @id
  parentId        String?
  type            McPlan_type
  title           String
  description     String?         @db.Text
  startDate       DateTime        @db.Date
  endDate         DateTime        @db.Date
  priority        Int             @default(3)
  status          McPlan_status   @default(DRAFT)
  source          String?
  workers         String?         @db.Text
  vendor          String?
  category        String?
  urgency         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  mcDaftarTugasId String?
  McBudget        McBudget[]
  McDailyTask     McDailyTask[]
  McDaftarTugas   McDaftarTugas?  @relation(fields: [mcDaftarTugasId], references: [id])
  McPlan          McPlan?         @relation("McPlanToMcPlan", fields: [parentId], references: [id])
  other_McPlan    McPlan[]        @relation("McPlanToMcPlan")
  McRealization   McRealization[]

  @@index([mcDaftarTugasId], map: "McPlan_mcDaftarTugasId_fkey")
  @@index([parentId], map: "McPlan_parentId_fkey")
}

model McRealization {
  id         String   @id
  planId     String
  actualCost Decimal  @db.Decimal(12, 0)
  spendDate  DateTime @db.Date
  proofImage String?
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  McPlan     McPlan   @relation(fields: [planId], references: [id])

  @@index([planId], map: "McRealization_planId_fkey")
}

model McRoutineSchedule {
  id            String                   @id
  routineTaskId String
  taskDate      DateTime                 @db.Date
  petugas       String                   @db.Text
  status        McRoutineSchedule_status @default(PENDING)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime
  McRoutineTask McRoutineTask            @relation(fields: [routineTaskId], references: [id])

  @@index([routineTaskId], map: "McRoutineSchedule_routineTaskId_fkey")
}

model McRoutineTask {
  id                String              @id
  aktivitas         String
  frekuensi         String
  jamMulai          String?
  jamSelesai        String?
  petugas           String?
  deskripsi         String?             @db.Text
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  McRoutineSchedule McRoutineSchedule[]
}

model McUnitRequest {
  id            String                @id
  unitName      String
  requesterName String
  description   String                @db.Text
  urgency       McUnitRequest_urgency @default(NORMAL)
  requestDate   DateTime              @default(now())
  status        McUnitRequest_status  @default(PENDING)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime
}

model McVendor {
  id        String   @id
  nama      String
  kategori  String
  kontak    String?
  alamat    String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model McWorker {
  id         String   @id
  nama       String
  kategori   String
  kontak     String?
  upahHarian Decimal  @db.Decimal(12, 0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime
}

// ==========================================
// ADMIN GROUP & ACTIVITY LOG
// ==========================================

model AdminGroup {
  id          String   @id @default(uuid())
  nama        String   @unique @db.VarChar(100)
  deskripsi   String?  @db.Text
  permissions Json?    // Array of strings (permissions)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]   @relation("UserToAdminGroup")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   @db.VarChar(100) // CREATE, UPDATE, DELETE, LOGIN, dll
  entity    String   @db.VarChar(100) // Nama modul atau tabel, misal Santri, Pembayaran
  entityId  String?  @db.VarChar(100) // ID entitas
  details   String?  @db.Text         // Deskripsi atau diff (JSON string)
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
}

